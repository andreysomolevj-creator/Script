    -- Поле ключа убрано

    addInput(10, 60, "AIM FOV:", AIM_ANGLE, function(n) AIM_ANGLE = math.clamp(n, 1, 180) end)
    addInput(10, 85, "Dodge°:", DODGE_ANGLE, function(n) DODGE_ANGLE = math.clamp(n, 1, 90) end)
    addInput(10, 110, "DodgeDist:", DODGE_DISTANCE, function(n) DODGE_DISTANCE = math.clamp(n, 1, 100) end)
    addInput(10, 135, "Speed:", WALK_SPEED, function(n)
        WALK_SPEED = math.clamp(n, 1, 500)
        if LocalPlayer.Character then
            local h = LocalPlayer.Character:FindFirstChild("Humanoid")
            if h then h.WalkSpeed = WALK_SPEED end
        end
    end)

    local function addButton(x, y, text, initial, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 100, 0, 30)
        btn.Position = UDim2.new(0, x, 0, y)
        local state = initial  -- теперь здесь реальное состояние переменной
        btn.BackgroundColor3 = state and Color3.fromRGB(0,150,0) or Color3.fromRGB(150,0,0)
        btn.Text = text .. ": " .. (state and "ON" or "OFF")
        btn.TextColor3 = Color3.fromRGB(255,255,255)
        btn.Font = Enum.Font.SourceSansBold
        btn.TextSize = 12
        btn.BorderSizePixel = 0
        btn.Parent = mainFrame
        btn.MouseButton1Click:Connect(function()
            state = not state
            btn.BackgroundColor3 = state and Color3.fromRGB(0,150,0) or Color3.fromRGB(150,0,0)
            btn.Text = text .. ": " .. (state and "ON" or "OFF")
            callback(state)
        end)
        return btn
    end

    -- Важно: передаём текущие значения переменных, а не false
    local espBtn = addButton(10, 165, "ESP", ESP_ENABLED, function(s)
        ESP_ENABLED = s
        if s then
            for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then updateESP(p) end end
        else
            for p, _ in pairs(playerHighlights) do removeESP(p) end
            playerHighlights = {}
        end
    end)

    local aimBtn = addButton(120, 165, "Aimbot", AIMBOT_ENABLED, function(s) AIMBOT_ENABLED = s end)
    local autoFireBtn = addButton(10, 200, "AutoFire", AUTO_FIRE_ENABLED, function(s) AUTO_FIRE_ENABLED = s end)
    local dodgeBtn = addButton(120, 200, "Dodge", DODGE_ENABLED, function(s) DODGE_ENABLED = s end)

    -- Перетаскивание только через titleBar
    local dragging, dragStart, frameStart = false, nil, nil
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            frameStart = mainFrame.Position
        end
    end)
    titleBar.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta.X, frameStart.Y.Scale, frameStart.Y.Offset + delta.Y)
        end
    end)
    titleBar.InputEnded:Connect(function(input)
        if dragging then
            savedMenuPosition = mainFrame.Position
            dragging = false
        end
    end)
end

-- ESP
local function createHighlight(character)
    local hl = Instance.new("Highlight")
    hl.Name = "JoJo_ESP"
    hl.Adornee = character
    hl.FillColor = ESP_COLOR
    hl.FillTransparency = ESP_FILL_TRANSPARENCY
    hl.OutlineColor = ESP_COLOR
    hl.OutlineTransparency = ESP_OUTLINE_TRANSPARENCY
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = character
    return hl
end

function updateESP(player)
    if not isActivated or not ESP_ENABLED then return end
    local char = player.Character
    if not char then return end
    if playerHighlights[player] then playerHighlights[player]:Destroy() end
    playerHighlights[player] = createHighlight(char)
end

function removeESP(player)
    if playerHighlights[player] then playerHighlights[player]:Destroy(); playerHighlights[player] = nil end
end

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        player.CharacterAdded:Connect(function() updateESP(player) end)
        if player.Character then updateESP(player) end
    end
end
Players.PlayerAdded:Connect(function(player)
    if player == LocalPlayer then return end
    player.CharacterAdded:Connect(function() updateESP(player) end)
    if player.Character then updateESP(player) end
end)
Players.PlayerRemoving:Connect(removeESP)

-- Aimbot (мгновенный)
local function getTargetPos(char)
    local head = char:FindFirstChild("Head")
    if head and head:IsA("BasePart") then return head.Position end
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    return root and root.Position + Vector3.new(0, 2, 0)
end

local function isEnemyAimingAtMe(enemyHead)
    if not LocalPlayer.Character then return false end
    local myRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return false end
    local look = enemyHead.CFrame.LookVector
    local dirToMe = (myRoot.Position - enemyHead.Position).Unit
    return math.deg(math.acos(math.clamp(look:Dot(dirToMe), -1, 1))) <= 30
end

local function findBestTarget()
    if not isActivated or not AIMBOT_ENABLED then return nil end
    local best, bestScore = nil, math.huge
    local camDir, camPos = Camera.CFrame.LookVector, Camera.CFrame.Position
    local maxRad = math.rad(AIM_ANGLE)
    local screenCenter = Camera.ViewportSize / 2

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local tPos = getTargetPos(plr.Character)
            if tPos then
                local dirTo = (tPos - camPos).Unit
                local angle = math.acos(math.clamp(camDir:Dot(dirTo), -1, 1))
                if angle <= maxRad and isVisibleToEnemy(tPos, plr.Character) then
                    local vec, onScreen = Camera:WorldToViewportPoint(tPos)
                    if onScreen and vec.Z > 0 then
                        local screenPos = Vector2.new(vec.X, vec.Y)
                        local score = (screenPos - screenCenter).Magnitude * 0.6 + (tPos - camPos).Magnitude * 0.4
                        local head = plr.Character:FindFirstChild("Head")
                        if head and isEnemyAimingAtMe(head) then score = score * 0.3 end
                        if score < bestScore then bestScore = score; best = plr end
                    end
                end
            end
        end
    end
    return best
end

local function runAimbot()
    if not isActivated or not AIMBOT_ENABLED then return false end
    local target = findBestTarget()
    if target then
        local tPos = getTargetPos(target.Character)
        if tPos then
            Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, tPos)
            return true
        end
    end
    return false
end

-- AutoFire (с задержкой, как раньше)
local function tryAutoFire(targetAquired)
    if not isActivated or not AUTO_FIRE_ENABLED or not targetAquired then return end
    local now = tick()
    if now - lastAutoFire >= AUTO_FIRE_COOLDOWN then
        lastAutoFire = now
        pcall(function()
            VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            task.wait(0.05)
            VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end)
    end
end

-- Dodge
local function dodge()
    if not isActivated or not DODGE_ENABLED then return end
    if tick() - lastDodgeTime < DODGE_COOLDOWN then return end
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local hum = char:FindFirstChild("Humanoid")
    if hum and hum:GetState() == Enum.HumanoidStateType.Dead then return end
    local myPos = root.Position

    local threatDir, enemyLook = nil, nil
    for _, enemy in ipairs(Players:GetPlayers()) do
        if enemy == LocalPlayer or not enemy.Character then continue end
        local head = enemy.Character:FindFirstChild("Head") or enemy.Character:FindFirstChild("HumanoidRootPart")
        if not head or not head:IsA("BasePart") then continue end
        local ePos = head.Position
        if (ePos - myPos).Magnitude > DODGE_RANGE then continue end
        if not isVisibleToEnemy(ePos, enemy.Character) then continue end
        local dirToMe = (myPos - ePos).Unit
        local angle = math.deg(math.acos(math.clamp(head.CFrame.LookVector:Dot(dirToMe), -1, 1)))
        if angle <= DODGE_ANGLE then
            threatDir = dirToMe
            enemyLook = head.CFrame.LookVector
            break
        end
    end

    if threatDir then
        local perp = Vector3.new(threatDir.Z, 0, -threatDir.X).Unit
        if enemyLook then
            local lookH = Vector3.new(enemyLook.X, 0, enemyLook.Z)
            if lookH.Magnitude > 0.01 then
                if lookH.Unit:Dot(perp) > 0 then perp = -perp end
            end
        end
        if isDirectionClear(myPos, perp, DODGE_DISTANCE) then
            root.CFrame = root.CFrame + perp * DODGE_DISTANCE
        elseif isDirectionClear(myPos, -perp, DODGE_DISTANCE) then
            root.CFrame = root.CFrame - perp * DODGE_DISTANCE
        else
            for test = DODGE_DISTANCE - 5, 1, -1 do
                if isDirectionClear(myPos, perp, test) then
                    root.CFrame = root.CFrame + perp * test
                    break
                end
            end
        end
        lastDodgeTime = tick()
    end
end

