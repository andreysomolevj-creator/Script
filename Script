-- // RAGE mode: ESP + 360 Aimbot + Auto-Dodge (anti-aim)
-- // ESP: красная подсветка всех игроков без имён
-- // Aimbot: мгновенный доворот на голову, комбинированный приоритет
-- // Dodge: уклонение, когда противник наводит прицел на вас
-- // Меню: перетаскиваемое, ввод угла, кнопки ESP/Aimbot/Dodge

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local Camera = Workspace.CurrentCamera

local LocalPlayer = Players.LocalPlayer

-- =================== НАСТРОЙКИ ПО УМОЛЧАНИЮ ===================
local ESP_ENABLED = true
local AIMBOT_ENABLED = true
local AIM_ANGLE = 180          -- обзор аимбота (180 = 360°)

-- ESP
local ESP_COLOR = Color3.fromRGB(255, 0, 0)
local ESP_FILL_TRANSPARENCY = 0.7
local ESP_OUTLINE_TRANSPARENCY = 0

-- Уклонение
local DODGE_ENABLED = true
local DODGE_ANGLE = 15        -- градусов (точность прицела врага для срабатывания)
local DODGE_RANGE = 50        -- дальность срабатывания (в стадах)
local DODGE_DISTANCE = 8      -- дистанция рывка в сторону
local DODGE_COOLDOWN = 0.5    -- секунд между уклонениями
-- ============================================================

local playerHighlights = {}
local lastDodgeTime = 0

-- =================== ESP ===================
local function createHighlight(character)
    local highlight = Instance.new("Highlight")
    highlight.Name = "RAGE_ESP"
    highlight.Adornee = character
    highlight.FillColor = ESP_COLOR
    highlight.FillTransparency = ESP_FILL_TRANSPARENCY
    highlight.OutlineColor = ESP_COLOR
    highlight.OutlineTransparency = ESP_OUTLINE_TRANSPARENCY
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = character
    return highlight
end

local function updateESP(player)
    local character = player.Character
    if not character then return end
    if playerHighlights[player] then
        playerHighlights[player]:Destroy()
        playerHighlights[player] = nil
    end
    playerHighlights[player] = createHighlight(character)
end

local function removeESP(player)
    if playerHighlights[player] then
        playerHighlights[player]:Destroy()
        playerHighlights[player] = nil
    end
end

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        player.CharacterAdded:Connect(function() updateESP(player) end)
        if player.Character then updateESP(player) end
    end
end

Players.PlayerAdded:Connect(function(player)
    if player == LocalPlayer then return end
    player.CharacterAdded:Connect(function() updateESP(player) end)
    if player.Character then updateESP(player) end
end)

Players.PlayerRemoving:Connect(removeESP)

-- =================== AIMBOT ===================
local function getAllParts(character)
    local parts = {}
    if character then
        for _, v in ipairs(character:GetDescendants()) do
            if v:IsA("BasePart") then table.insert(parts, v) end
        end
    end
    return parts
end

local function getTargetPosition(character)
    local head = character:FindFirstChild("Head")
    if head and head:IsA("BasePart") then return head.Position end
    local root = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
    if root and root:IsA("BasePart") then return root.Position + Vector3.new(0, 2, 0) end
    return nil
end

local function worldToScreen(point)
    local vec, onScreen = Camera:WorldToViewportPoint(point)
    return Vector2.new(vec.X, vec.Y), onScreen, vec.Z
end

local function isVisible(targetPosition, targetCharacter)
    if not targetCharacter then return false end
    local cameraPos = Camera.CFrame.Position
    local direction = (targetPosition - cameraPos).Unit
    local rayDistance = (targetPosition - cameraPos).Magnitude
    local ignoreList = {}
    local localParts = getAllParts(LocalPlayer.Character)
    local targetParts = getAllParts(targetCharacter)
    for _, part in ipairs(localParts) do table.insert(ignoreList, part) end
    for _, part in ipairs(targetParts) do table.insert(ignoreList, part) end
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = ignoreList
    raycastParams.IgnoreWater = true
    local rayResult = Workspace:Raycast(cameraPos, direction * rayDistance, raycastParams)
    return rayResult == nil
end

local function findBestTarget()
    local bestTarget = nil
    local bestScore = math.huge
    local screenCenter = Camera.ViewportSize / 2
    local camDir = Camera.CFrame.LookVector
    local camPos = Camera.CFrame.Position
    local maxAngleRad = math.rad(AIM_ANGLE)
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not player.Character then continue end
        local targetPos = getTargetPosition(player.Character)
        if not targetPos then continue end
        local dirToTarget = (targetPos - camPos).Unit
        local dot = camDir:Dot(dirToTarget)
        local angle = math.acos(math.clamp(dot, -1, 1))
        if angle > maxAngleRad then continue end
        if not isVisible(targetPos, player.Character) then continue end
        local screenPos, onScreen, depth = worldToScreen(targetPos)
        if not onScreen or depth <= 0 then continue end
        local distToCenter = (screenPos - screenCenter).Magnitude
        local distance3D = (targetPos - camPos).Magnitude
        local score = distToCenter * 0.6 + distance3D * 0.4
        if score < bestScore then
            bestScore = score
            bestTarget = player
        end
    end
    return bestTarget
end

local function instantAim(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    local targetPos = getTargetPosition(targetPlayer.Character)
    if not targetPos then return end
    Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, targetPos)
end

-- =================== Уклонение ===================
local function checkDodge()
    if not DODGE_ENABLED then return end
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid or humanoid:GetState() == Enum.HumanoidStateType.Dead then return end
    local myPos = root.Position

    local now = tick()
    if now - lastDodgeTime < DODGE_COOLDOWN then return end

    for _, enemy in ipairs(Players:GetPlayers()) do
        if enemy == LocalPlayer then continue end
        if not enemy.Character then continue end
        local enemyHead = enemy.Character:FindFirstChild("Head")
        if not enemyHead or not enemyHead:IsA("BasePart") then continue end
        local enemyPos = enemyHead.Position
        local distance = (enemyPos - myPos).Magnitude
        if distance > DODGE_RANGE then continue end
        local enemyLook = enemyHead.CFrame.LookVector
        local dirToMe = (myPos - enemyPos).Unit
        local dot = enemyLook:Dot(dirToMe)
        local angle = math.deg(math.acos(math.clamp(dot, -1, 1)))
        if angle <= DODGE_ANGLE then
            -- Враг целится в нас, выполняем рывок в сторону
            local rightVector = enemyHead.CFrame.RightVector
            -- Случайно влево или вправо относительно линии взгляда врага
            local dodgeDir = (math.random() < 0.5 and rightVector or -rightVector)
            local newPos = root.Position + dodgeDir * DODGE_DISTANCE
            root.CFrame = CFrame.new(newPos)
            lastDodgeTime = now
            break -- одно уклонение за кадр
        end
    end
end

-- Главный цикл
RunService.RenderStepped:Connect(function()
    if AIMBOT_ENABLED then
        local target = findBestTarget()
        if target then
            instantAim(target)
        end
    end
    checkDodge()
end)

