-- Утилиты
local function getAllParts(char)
    local parts = {}
    if char then
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("BasePart") then table.insert(parts, v) end
        end
    end
    return parts
end

local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Blacklist
rayParams.IgnoreWater = true

local function isVisibleToEnemy(enemyHeadPos, enemyChar)
    if not enemyChar or not LocalPlayer.Character then return false end
    local myPos = Camera.CFrame.Position
    local dir = (myPos - enemyHeadPos).Unit
    local rayDistance = (myPos - enemyHeadPos).Magnitude
    local ignore = {}
    for _, p in ipairs(getAllParts(LocalPlayer.Character)) do table.insert(ignore, p) end
    for _, p in ipairs(getAllParts(enemyChar)) do table.insert(ignore, p) end
    rayParams.FilterDescendantsInstances = ignore
    return Workspace:Raycast(enemyHeadPos, dir * rayDistance, rayParams) == nil
end

local function isDirectionClear(origin, dir, distance)
    local ignore = {}
    if LocalPlayer.Character then
        for _, p in ipairs(getAllParts(LocalPlayer.Character)) do table.insert(ignore, p) end
    end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            for _, p in ipairs(getAllParts(plr.Character)) do table.insert(ignore, p) end
        end
    end
    rayParams.FilterDescendantsInstances = ignore
    return Workspace:Raycast(origin, dir * distance, rayParams) == nil
end

