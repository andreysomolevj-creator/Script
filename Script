local function gp(ch)
    local t={}
    if ch then for _,v in ipairs(ch:GetDescendants()) do if v:IsA("BasePart") then t[#t+1]=v end end end
    return t
end

local rp=RaycastParams.new()
rp.FilterType=Enum.RaycastFilterType.Blacklist
rp.IgnoreWater=true

local function ve(ep,ec_)
    if not ec_ or not l.Character then return false end
    local mp_=c.CFrame.Position
    local d=(mp_-ep).Unit
    local dist=(mp_-ep).Magnitude
    local ig={}
    for _,v in ipairs(gp(l.Character)) do ig[#ig+1]=v end
    for _,v in ipairs(gp(ec_)) do ig[#ig+1]=v end
    rp.FilterDescendantsInstances=ig
    return w:Raycast(ep, d*dist, rp)==nil
end

local function dc(o,di,dist)
    local ig={}
    if l.Character then for _,v in ipairs(gp(l.Character)) do ig[#ig+1]=v end end
    for _,pl in ipairs(p:GetPlayers()) do
        if pl~=l and pl.Character then for _,v in ipairs(gp(pl.Character)) do ig[#ig+1]=v end end
    end
    rp.FilterDescendantsInstances=ig
    return w:Raycast(o, di*dist, rp)==nil
end

