        espButton.Text = "ESP: ON"
        espButton.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then updateESP(player) end
        end
    else
        espButton.Text = "ESP: OFF"
        espButton.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
        for player, _ in pairs(playerHighlights) do
            removeESP(player)
        end
        playerHighlights = {}
    end
end)

