-- ESP
local function ch_(char)
    local hl=Instance.new("Highlight")
    hl.Name="Highlight"
    hl.Adornee=char
    hl.FillColor=ec
    hl.FillTransparency=ef
    hl.OutlineColor=ec
    hl.OutlineTransparency=eo
    hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent=char
    return hl
end

function ue(pl)
    if not ia or not ee then return end
    local char=pl.Character
    if not char then return end
    if h[pl] then h[pl]:Destroy() end
    h[pl]=ch_(char)
end

function re(pl)
    if h[pl] then h[pl]:Destroy() h[pl]=nil end
end

for _,pl in ipairs(p:GetPlayers()) do
    if pl~=l then
        pl.CharacterAdded:Connect(function() ue(pl) end)
        if pl.Character then ue(pl) end
    end
end
p.PlayerAdded:Connect(function(pl)
    if pl==l then return end
    pl.CharacterAdded:Connect(function() ue(pl) end)
    if pl.Character then ue(pl) end
end)
p.PlayerRemoving:Connect(re)

-- Aimbot
local function gtp(char)
    local hd=char:FindFirstChild("Head")
    if hd and hd:IsA("BasePart") then return hd.Position end
    local rt=char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    return rt and rt.Position+Vector3.new(0,2,0)
end

local function eam(hd)
    if not l.Character then return false end
    local mr=l.Character:FindFirstChild("HumanoidRootPart")
    if not mr then return false end
    local look=hd.CFrame.LookVector
    local dtm=(mr.Position-hd.Position).Unit
    return math.deg(math.acos(math.clamp(look:Dot(dtm),-1,1)))<=30
end

local function fbt()
    if not ia or not ae then return nil end
    local best,bscore=nil,math.huge
    local cd,cp=c.CFrame.LookVector,c.CFrame.Position
    local mr=math.rad(aa)
    local sc=c.ViewportSize/2
    for _,pl in ipairs(p:GetPlayers()) do
        if pl~=l and pl.Character then
            local tp=gtp(pl.Character)
            if tp then
                local dt=(tp-cp).Unit
                local ang=math.acos(math.clamp(cd:Dot(dt),-1,1))
                if ang<=mr and ve(tp,pl.Character) then
                    local vec,ons=c:WorldToViewportPoint(tp)
                    if ons and vec.Z>0 then
                        local sp=Vector2.new(vec.X,vec.Y)
                        local sc2=(sp-sc).Magnitude*0.6+(tp-cp).Magnitude*0.4
                        local hd=pl.Character:FindFirstChild("Head")
                        if hd and eam(hd) then sc2=sc2*0.3 end
                        if sc2<bscore then bscore=sc2 best=pl end
                    end
                end
            end
        end
    end
    return best
end

local function ra()
    if not ia or not ae then return false end
    local t=fbt()
    if t then
        local tp=gtp(t.Character)
        if tp then c.CFrame=CFrame.lookAt(c.CFrame.Position,tp) return true end
    end
    return false
end

-- AutoFire
local function taf(ta_)
    if not ia or not af or not ta_ then return end
    local now=tick()
    if now-laf>=acd*(0.8+math.random()*0.4) then
        laf=now
        pcall(function()
            v:SendMouseButtonEvent(0,0,0,true,game,0)
            task.wait(0.03+math.random()*0.04)
            v:SendMouseButtonEvent(0,0,0,false,game,0)
        end)
    end
end

-- Dodge
local function dod()
    if not ia or not de then return end
    if tick()-ld<dcd*(0.9+math.random()*0.2) then return end
    local char=l.Character
    if not char then return end
    local root=char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local hum=char:FindFirstChild("Humanoid")
    if hum and hum:GetState()==Enum.HumanoidStateType.Dead then return end
    local my=root.Position
    local td_,el=nil,nil
    for _,en in ipairs(p:GetPlayers()) do
        if en==l or not en.Character then continue end
        local hd=en.Character:FindFirstChild("Head") or en.Character:FindFirstChild("HumanoidRootPart")
        if not hd or not hd:IsA("BasePart") then continue end
        local ep=hd.Position
        if (ep-my).Magnitude>dr then continue end
        if not ve(ep,en.Character) then continue end
        local dm=(my-ep).Unit
        local ang=math.deg(math.acos(math.clamp(hd.CFrame.LookVector:Dot(dm),-1,1)))
        if ang<=da then td_=dm el=hd.CFrame.LookVector break end
    end
    if td_ then
        local perp=Vector3.new(td_.Z,0,-td_.X).Unit
        if el then
            local lh=Vector3.new(el.X,0,el.Z)
            if lh.Magnitude>0.01 then if lh.Unit:Dot(perp)>0 then perp=-perp end end
        end
        if dc(my,perp,dd) then root.CFrame=root.CFrame+perp*dd
        elseif dc(my,-perp,dd) then root.CFrame=root.CFrame-perp*dd
        else for test=dd-5,1,-1 do if dc(my,perp,test) then root.CFrame=root.CFrame+perp*test break end end
        end
        ld=tick()
    end
end

-- Main loop
r.RenderStepped:Connect(function()
    local ta_=ra()
    taf(ta_)
    dod()
end)

