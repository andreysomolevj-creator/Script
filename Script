        inp.Position = UDim2.new(0, x + 95, 0, y - 1)
        inp.BackgroundColor3 = Color3.fromRGB(50,50,50)
        inp.TextColor3 = Color3.fromRGB(255,255,255)
        inp.Font = Enum.Font.SourceSans
        inp.TextSize = 12
